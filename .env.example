# ==============================================================================
# Sentinel Trader Configuration (.env)
# ==============================================================================

# ── AI Brain ────────────────────────────────────────────────────────────────
GEMINI_API_KEY="your_google_gemini_api_key_here"
# GEMINI_MODEL="gemini-3.1-flash-lite"

# Second Gemini key — doubles effective RPM (same model, separate quota)
# GEMINI_API_KEY_2="your_second_gemini_api_key_here"
# AI_PROVIDER="gemini_dual"   # auto-set when both GEMINI_API_KEY and GEMINI_API_KEY_2 are present
# GEMINI_KEY1_MAX_DAILY_CALLS=0        # paid key RPD cap (0=unlimited; 3.1 Flash Lite ≈150K)
# GEMINI_KEY2_MAX_DAILY_CALLS=300      # free-tier backup RPD cap (0=unlimited)
# GEMINI_KEY1_MAX_RPM=120              # paid key RPM (3.1 Flash Lite ≈4K; 0=use AI_MAX_RPM)
# GEMINI_KEY2_MAX_RPM=10               # free-tier backup RPM — keep low

# NVIDIA NIM — optional fallback (Gemini primary, NVIDIA on RPM cap / 429)
# Get a free key at: https://build.nvidia.com/
# NVIDIA_API_KEY="your_nvidia_api_key_here"
# NVIDIA_MODEL="meta/llama-3.3-70b-instruct"
# AI_PROVIDER="dual"   # auto-set when both GEMINI_API_KEY and NVIDIA_API_KEY are present

# ── Live Execution ──────────────────────────────────────────────────────────
MEXC_API_KEY="your_mexc_api_key_here"
MEXC_SECRET_KEY="your_mexc_secret_key_here"

# ── Telegram Admin (optional) ───────────────────────────────────────────────
# Leave empty or "dummy" to run without Telegram; bot still scans and trades.
# TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
# TELEGRAM_ADMIN_CHAT_ID=123456789

# ── News Sentiment (Optional) ───────────────────────────────────────────────
CRYPTOPANIC_API_TOKEN=""  # Leave empty to disable news fetching

# ==============================================================================
# OPTIONAL TUNABLES (Leave commented to use defaults)
# ==============================================================================
# AI_MAX_RPM=120         # Default RPM for paid Gemini key 1
# GEMINI_KEY1_MAX_RPM=120
# GEMINI_KEY2_MAX_RPM=15 # Free-tier backup — only used when key 1 errors
# NVIDIA_MAX_RPM=30      # NVIDIA spillover limit in dual mode
# SCAN_STAGGER_SEC=5.0   # Delay between symbol pipeline starts
# SCAN_SYMBOLS="BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,BNB/USDT,DOGE/USDT,AVAX/USDT,LINK/USDT"
# RISK_PER_TRADE_PCT=0.5
# MAX_LEVERAGE=3
# MAX_NOTIONAL_PER_SYMBOL_USDT=1000.0
